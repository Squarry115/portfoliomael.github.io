<main class="under-construction-page">
  <style>
    .under-construction-page{min-height:70vh;display:flex;align-items:center;justify-content:center;padding:4rem 1rem;background:linear-gradient(135deg,#f7f8fb,#eef4ff);}
    .uc-container{max-width:720px;text-align:center;padding:2rem;border-radius:14px}
    .uc-image{width:60%;max-width:380px;height:auto;display:block;margin:0 auto 1.25rem;border-radius:10px;box-shadow:0 12px 30px rgba(37,50,90,0.08)}
    .uc-title{color:var(--accent-purple,#6b3bd6);font-size:2rem;margin:0 0 .5rem}
    .uc-text{color:#444;margin-bottom:1rem;font-size:1.05rem}
    .btn-return{display:inline-block;padding:.6rem 1rem;background:var(--accent-purple,#6b3bd6);color:#fff;border-radius:8px;text-decoration:none;transition:transform .15s ease}
    .btn-return:hover{transform:translateY(-3px)}
    @media (max-width:520px){.uc-image{width:85%}.uc-title{font-size:1.5rem}}
  </style>

  <div class="uc-container">
    <img src="/images/web_working.jpg" alt="Page en construction" class="uc-image" />
    <h1 class="uc-title">Page en construction</h1>
    <p class="uc-text">Cette page est en cours de réalisation. Revenez bientôt pour voir le contenu final — merci de votre patience !</p>
    <a href="/" class="btn-return">Retour à l'accueil</a>
  </div>
</main>
